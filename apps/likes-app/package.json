{
  "name": "likes-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "serve": "ng serve",
    "serve:prod": "ng serve --configuration=production",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "deploy": "firebase deploy",
    "clean": "rimraf .angular && rimraf dist",
    "dev:ssr": "ng run likes-app:serve-ssr",
    "serve:ssr": "node dist/likes-app/server/main.js",
    "build:ssr": "ng build && ng run likes-app:server",
    "prerender": "ng run likes-app:prerender"
  },
  "private": true,
  "dependencies": {
    "@youtube/common-ui": "*"
  }
}
